#include <Adafruit_GFX.h>
#include <Adafruit_SH110X.h>
#include <Fonts/TomThumb.h>
#include <SPI.h>
#include <Wire.h>

#define MPU 0x68

Adafruit_SH1106G display = Adafruit_SH1106G(128, 64, &Wire);

float accX, accY, accZ;
float gyroX, gyroY, gyroZ;
float gyroXoffset, gyroYoffset, gyroZoffset;
float accXoffset, accYoffset, accZoffset;

void setup() {
  Serial.begin(115200);
  Wire.begin(4, 5);

  Wire.beginTransmission(MPU);
  Wire.write(0x6B);
  Wire.write(0x00);
  Wire.endTransmission(true);

  display.begin(0x3c);

  long gXsum = 0, gYsum = 0, gZsum = 0;
  long aXsum = 0, aYsum = 0, aZsum = 0;

  Serial.println("Calibrating... keep sensor still!");

  for (int i = 0; i < 1000; i++) {
    Wire.beginTransmission(MPU);
    Wire.write(0x3B);
    Wire.endTransmission(false);
    Wire.requestFrom(MPU, 14, true);

    aXsum += (int16_t)(Wire.read() << 8 | Wire.read());
    aYsum += (int16_t)(Wire.read() << 8 | Wire.read());
    aZsum += (int16_t)(Wire.read() << 8 | Wire.read());
    Wire.read(); Wire.read();                 // skip temp
    gXsum += (int16_t)(Wire.read() << 8 | Wire.read());
    gYsum += (int16_t)(Wire.read() << 8 | Wire.read());
    gZsum += (int16_t)(Wire.read() << 8 | Wire.read());

    delay(2);
  }

  accXoffset = aXsum / 1000.0 / 16384.0;
  accYoffset = aYsum / 1000.0 / 16384.0;
  accZoffset = aZsum / 1000.0 / 16384.0;

  gyroXoffset = gXsum / 1000.0 / 131.0;
  gyroYoffset = gYsum / 1000.0 / 131.0;
  gyroZoffset = gZsum / 1000.0 / 131.0;
  Serial.println("Calibration done!");
}

void loop() {
  Wire.beginTransmission(MPU);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU, 14, true);

  accX = (int16_t)(Wire.read() << 8 | Wire.read()) / 16384.0 - accXoffset;
  accY = (int16_t)(Wire.read() << 8 | Wire.read()) / 16384.0 - accYoffset;
  accZ = (int16_t)(Wire.read() << 8 | Wire.read()) / 16384.0 - accZoffset;
  Wire.read(); Wire.read(); // skip temperature
  gyroX = (int16_t)(Wire.read() << 8 | Wire.read()) / 131.0 - gyroXoffset;
  gyroY = (int16_t)(Wire.read() << 8 | Wire.read()) / 131.0 - gyroYoffset;
  gyroZ = (int16_t)(Wire.read() << 8 | Wire.read()) / 131.0 - gyroZoffset;

  // serial monitor update
  Serial.print("aX:"); Serial.print(accX);
  Serial.print(" aY:"); Serial.print(accY);
  Serial.print(" aZ:"); Serial.println(accZ);
  Serial.print("gX:"); Serial.print(gyroX);
  Serial.print(" gY:"); Serial.print(gyroY);
  Serial.print(" gZ:"); Serial.println(gyroZ);
  Serial.println("");

  display.clearDisplay();
  display.setFont(&TomThumb);
  display.setCursor(3, 7);
  display.setTextColor(SH110X_WHITE);
  display.setTextSize(1);
  display.print("aX:"); display.print(accX);
  display.print(" aY:"); display.print(accY);
  display.print(" aZ:"); display.println(accZ);

  display.setCursor(3, 14);
  display.print("gX:"); display.print(gyroX);
  display.print(" gY:"); display.print(gyroY);
  display.print(" gZ:"); display.println(gyroZ);
  display.println("");
  display.drawRect(0, 0, 128, 64, SH110X_WHITE);
  display.display();

  delay(100);
}
